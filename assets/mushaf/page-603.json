{"page":603,"lines":[{"line":1,"type":"surah-header","text":"سورة الكافرون","surah":"109"},{"line":2,"type":"basmala","qpcV2":"ﭑﭒﭓ"},{"line":3,"type":"text","text":"قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ ١ لَآ أَعْبُدُ مَا تَعْبُدُونَ ٢","verseRange":"109:1-109:2","words":[{"location":"109:1:1","word":"قُلْ","qpcV2":"ﱁ","tj":"قُلۡ"},{"location":"109:1:2","word":"يَـٰٓأَيُّهَا","qpcV2":"ﱂ","tj":"يَ<rule class=madda_obligatory_mottasel>ـٰٓ</rule>أَيُّهَا"},{"location":"109:1:3","word":"ٱلْكَـٰفِرُونَ ١","qpcV2":"ﱃ ﱄ","tj":"<rule class=ham_wasl>ٱ</rule>لۡكَ<rule class=madda_normal>ـٰ</rule>فِر<rule class=madda_permissible>ُو</rule>نَ"},{"location":"109:2:1","word":"لَآ","qpcV2":"ﱅ","tj":"ل<rule class=madda_obligatory_monfasel>َآ</rule>"},{"location":"109:2:2","word":"أَعْبُدُ","qpcV2":"ﱆ","tj":"أَعۡبُدُ"},{"location":"109:2:3","word":"مَا","qpcV2":"ﱇ","tj":"مَا"},{"location":"109:2:4","word":"تَعْبُدُونَ ٢","qpcV2":"ﱈ ﱉ","tj":"تَعۡبُد<rule class=madda_permissible>ُو</rule>نَ"}]},{"line":4,"type":"text","text":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ ٣ وَلَآ أَنَا۠ عَابِدٌۭ مَّا عَبَدتُّمْ ٤","verseRange":"109:3-109:4","words":[{"location":"109:3:1","word":"وَلَآ","qpcV2":"ﱊ","tj":"وَل<rule class=madda_obligatory_monfasel>َآ</rule>"},{"location":"109:3:2","word":"أَنتُمْ","qpcV2":"ﱋ","tj":"أَ<rule class=ikhafa>نت</rule>ُمۡ"},{"location":"109:3:3","word":"عَـٰبِدُونَ","qpcV2":"ﱌ","tj":"عَ<rule class=madda_normal>ـٰ</rule>بِدُونَ"},{"location":"109:3:4","word":"مَآ","qpcV2":"ﱍ","tj":"م<rule class=madda_obligatory_monfasel>َآ</rule>"},{"location":"109:3:5","word":"أَعْبُدُ ٣","qpcV2":"ﱎ ﱏ","tj":"أَعۡبُ<rule class=qalaqah>د</rule>ُ"},{"location":"109:4:1","word":"وَلَآ","qpcV2":"ﱐ","tj":"وَل<rule class=madda_obligatory_monfasel>َآ</rule>"},{"location":"109:4:2","word":"أَنَا۠","qpcV2":"ﱑ","tj":"أَنَاۡ"},{"location":"109:4:3","word":"عَابِدٌۭ","qpcV2":"ﱒ","tj":"عَابِ<rule class=idgham_ghunnah>دٌ</rule>"},{"location":"109:4:4","word":"مَّا","qpcV2":"ﱓ","tj":"<rule class